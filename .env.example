# ─── Telegram ────────────────────────────────────────────────────────────────
# Create a bot with @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Comma-separated list of Telegram numeric user IDs allowed to talk to the bot.
# Get yours by messaging @userinfobot. Ares ignores everyone else.
# Leave empty ONLY for local testing — an open bot will run code on your machine.
TELEGRAM_ALLOWED_USER_IDS=11111111,22222222

# ─── Claude / Anthropic ────────────────────────────────────────────────────────
# OPTIONAL. Auth flows through the `claude` binary (subscription session or
# CLAUDE_CODE_OAUTH_TOKEN). Only set this as a fallback if you use API key auth.
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Agent workspace ───────────────────────────────────────────────────────────
# Fallback working directory when no project is defined/selected. Defaults to CWD.
ARES_WORKSPACE_DIR=.

# Max agentic turns per request before the agent must return to you.
ARES_MAX_TURNS=40

# ─── Storage & projects ────────────────────────────────────────────────────────
# Where Ares persists per-chat sessions, schedules, and run output. Defaults to ./data
ARES_DATA_DIR=data

# Projects definition file (see ares.projects.example.json). Optional —
# without it, a single "default" project rooted at ARES_WORKSPACE_DIR is used.
ARES_PROJECTS_FILE=ares.projects.json

# OPTIONAL. Where to search for your projects (comma-separated, ~ allowed).
# Leave it UNSET and Ares searches your whole home directory recursively — so you
# can just say "/open dafne-api" with zero config. Set it only to narrow/speed up
# the search to specific folders, e.g. ARES_PROJECTS_ROOTS=~/proyectos,~/work
# ARES_PROJECTS_ROOTS=

# How many directory levels deep to search (default 6).
# ARES_PROJECTS_DEPTH=6
