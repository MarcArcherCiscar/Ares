{
  "name": "ares",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram bridge to your personal Claude Code agent — a manager agent that dispatches subagents, for developers.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "croner": "^8.1.0",
    "dotenv": "^16.4.5",
    "grammy": "^1.30.0",
    "playwright": "^1.47.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
